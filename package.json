{
  "name": "reason",
  "version": "0.1.0",
  "description": "Local-first reasoning repository for worldview revision",
  "type": "module",
  "bin": {
    "reason": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.js",
    "compile": "bun build src/cli.ts --compile --outfile reason",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
